# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Compiled output
dist
tmp
out-tsc

# Dependencies
node_modules

# Nx
.nx/cache
.nx/workspace-data
.nx/polygraph
.nx/self-healing
.nx/migrate-runs

# Angular
.angular

# Storybook (build output goes to dist/storybook; ignore defaults + logs)
storybook-static
*storybook.log
.storybook-out

# Testing / coverage
/coverage
test-results
playwright-report
/.playwright

# Visual regression: only Linux baselines are canonical (generated in CI).
# Local throwaway baselines for other OSes must never be committed.
**/__screenshots__/**/*-win32.png
**/__screenshots__/**/*-darwin.png

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Husky — the generated hook shims are regenerated by `prepare` on install
# (husky also writes its own .husky/_/.gitignore); only .husky/<hook> is tracked.
.husky/_/

# VSCode — keep shared workspace settings, ignore the rest
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Claude Code — keep shared project config, ignore local/personal state
.claude/settings.local.json
.claude/worktrees

# Bundler/build timestamps
vite.config.*.timestamp*
vitest.config.*.timestamp*

# System files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-error.log
pnpm-debug.log*
