{
  "name": "designer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "rdr",
  "sourceRoot": "apps/designer/src",
  "tags": ["scope:designer", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/designer",
        "browser": "apps/designer/src/main.ts",
        "tsConfig": "apps/designer/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/designer/public"
          }
        ],
        "styles": ["libs/ui-kit/src/styles/tokens.css", "apps/designer/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "configurations": {
        "production": {
          "buildTarget": "designer:build:production"
        },
        "development": {
          "buildTarget": "designer:build:development"
        }
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "designer:build",
        "staticFilePath": "dist/apps/designer/browser",
        "spa": true
      }
    },
    "test": {
      "outputs": [
        "{projectRoot}/{options.coverage.reportsDirectory}",
        "{workspaceRoot}/coverage/apps/designer"
      ],
      "options": {
        "coverage.reportsDirectory": "../../coverage/apps/designer"
      }
    }
  }
}
