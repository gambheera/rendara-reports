{
  "name": "@rendara/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "graph": "nx graph",
    "lint": "nx run-many -t lint",
    "lint:affected": "nx affected -t lint",
    "test": "nx run-many -t test",
    "test:affected": "nx affected -t test",
    "e2e": "nx run-many -t e2e",
    "visual": "nx run visual-e2e:visual",
    "visual:update": "nx run visual-e2e:visual:update",
    "storybook:build": "nx run-many -t build-storybook",
    "storybook:compose": "storybook dev -p 4500 --no-open -c .storybook",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "nx report && nx graph --file=tmp/graph.json && nx run-many -t lint && prettier --check .",
    "changeset": "changeset",
    "release:status": "changeset status --verbose",
    "release:version": "changeset version",
    "release:dry-run": "pnpm -r publish --dry-run --no-git-checks",
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/router": "21.2.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.1",
    "@analogjs/vitest-angular": "2.6.1",
    "@angular-devkit/build-angular": "21.2.7",
    "@angular-devkit/core": "21.2.7",
    "@angular-devkit/schematics": "21.2.7",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@angular/language-service": "21.2.9",
    "@axe-core/playwright": "4.11.3",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "23.0.0",
    "@nx/devkit": "23.0.0",
    "@nx/eslint": "23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/playwright": "23.0.0",
    "@nx/vite": "23.0.0",
    "@nx/vitest": "23.0.0",
    "@nx/web": "23.0.0",
    "@nx/workspace": "23.0.0",
    "@playwright/test": "1.61.0",
    "@schematics/angular": "21.2.7",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/angular": "10.4.6",
    "@storybook/html-vite": "10.4.6",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@testing-library/angular": "19.4.1",
    "@testing-library/dom": "10.4.0",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "3.2.4",
    "angular-eslint": "21.3.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "jsdom": "25.0.1",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.0",
    "prettier": "^3.8.1",
    "storybook": "10.4.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
