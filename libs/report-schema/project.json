{
  "name": "report-schema",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/report-schema/src",
  "projectType": "library",
  "tags": ["scope:schema", "type:util"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "command": "node tools/bundle-schema.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "pack": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "commands": ["node tools/verify-schema-pack.mjs", "node tools/verify-schema-node.mjs"],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-schema": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r @swc-node/register tools/generate-schema.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-fixtures": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r @swc-node/register tools/generate-fixtures.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "outputs": [
        "{projectRoot}/{options.coverage.reportsDirectory}",
        "{workspaceRoot}/coverage/libs/report-schema"
      ],
      "options": {
        "coverage.reportsDirectory": "../../coverage/libs/report-schema"
      }
    }
  }
}
