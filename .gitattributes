# Normalize line endings to LF in the repository for all text files so the
# toolchain (Prettier, ESLint, editorconfig) behaves identically across OSes.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# Lockfile is generated; keep it out of language stats and diffs.
pnpm-lock.yaml -diff linguist-generated
